#include <ESP32Servo.h>

// ===================== SERVO OBJECTS =====================
Servo capServo;
Servo doorServo;
Servo collectorServo;

// ===================== PINS =====================
// Change these to your actual servo signal pins
#define CAP_SERVO_PIN        IO15
#define DOOR_SERVO_PIN       IO13
#define COLLECTOR_SERVO_PIN  IO12

// ===================== SPEED =====================
const int stepDelay = 30;   // all movement must be slow

// ===================== STARTUP POSITIONS =====================
int capCurrentAngle = 90;         // cap servo startup position
int doorCurrentAngle = 40;        // door servo startup position
int collectorCurrentAngle = 103;  // collector servo startup position

// ===================== LIMITS =====================
const int capMinAngle = 5;
const int capMaxAngle = 90;

const int doorMinAngle = 40;
const int doorMaxAngle = 160;

// collector only allows 0, 103, 180

String inputLine = "";

// ===================== SLOW MOVE FUNCTION =====================
void slowMoveServo(Servo &servo, int &currentAngle, int targetAngle) {
  if (currentAngle < targetAngle) {
    for (int angle = currentAngle; angle <= targetAngle; angle++) {
      servo.write(angle);
      delay(stepDelay);
    }
  } else if (currentAngle > targetAngle) {
    for (int angle = currentAngle; angle >= targetAngle; angle--) {
      servo.write(angle);
      delay(stepDelay);
    }
  }

  currentAngle = targetAngle;
}

// ===================== HELP =====================
void printHelp() {
  Serial.println();
  Serial.println("=== 3-Servo Manual Test Commands ===");
  Serial.println("cap <angle>        -> cap servo moves between 5 and 90");
  Serial.println("door <angle>       -> door servo moves between 40 and 160");
  Serial.println("collector <angle>  -> collector servo only accepts 0, 103, or 180");
  Serial.println("status             -> show current tracked positions");
  Serial.println("help               -> show this help");
  Serial.println();
  Serial.println("Examples:");
  Serial.println("cap 20");
  Serial.println("door 120");
  Serial.println("collector 0");
  Serial.println("collector 103");
  Serial.println("collector 180");
  Serial.println();
}

// ===================== STATUS =====================
void printStatus() {
  Serial.println();
  Serial.println("Current servo positions:");
  Serial.print("Cap: ");
  Serial.println(capCurrentAngle);

  Serial.print("Door: ");
  Serial.println(doorCurrentAngle);

  Serial.print("Collector: ");
  Serial.println(collectorCurrentAngle);
  Serial.println();
}

// ===================== PROCESS COMMAND =====================
void processCommand(String cmd) {
  cmd.trim();
  cmd.toLowerCase();

  if (cmd.length() == 0) return;

  if (cmd == "help") {
    printHelp();
    return;
  }

  if (cmd == "status") {
    printStatus();
    return;
  }

  int spaceIndex = cmd.indexOf(' ');
  if (spaceIndex == -1) {
    Serial.println("Invalid command. Use: c 20, d 120, t 103");
    return;
  }

  String servoName = cmd.substring(0, spaceIndex);
  String angleText = cmd.substring(spaceIndex + 1);
  angleText.trim();

  int targetAngle = angleText.toInt();

  // CAP SERVO
  if (servoName == "c") {
    if (targetAngle < capMinAngle || targetAngle > capMaxAngle) {
      Serial.print("Cap servo angle must be between ");
      Serial.print(capMinAngle);
      Serial.print(" and ");
      Serial.println(capMaxAngle);
      return;
    }

    Serial.print("Moving CAP servo to ");
    Serial.println(targetAngle);
    slowMoveServo(capServo, capCurrentAngle, targetAngle);
    Serial.println("CAP servo done.");
    return;
  }

  // DOOR SERVO
  if (servoName == "d") {
    if (targetAngle < doorMinAngle || targetAngle > doorMaxAngle) {
      Serial.print("Door servo angle must be between ");
      Serial.print(doorMinAngle);
      Serial.print(" and ");
      Serial.println(doorMaxAngle);
      return;
    }

    Serial.print("Moving DOOR servo to ");
    Serial.println(targetAngle);
    slowMoveServo(doorServo, doorCurrentAngle, targetAngle);
    Serial.println("DOOR servo done.");
    return;
  }

  // COLLECTOR SERVO
  if (servoName == "t") {
    if (!(targetAngle == 0 || targetAngle == 103 || targetAngle == 180)) {
      Serial.println("Collector servo only accepts: 0, 103, or 180");
      return;
    }

    Serial.print("Moving COLLECTOR servo to ");
    Serial.println(targetAngle);
    slowMoveServo(collectorServo, collectorCurrentAngle, targetAngle);
    Serial.println("COLLECTOR servo done.");
    return;
  }

  Serial.println("Unknown servo name. Use: cap, door, or collector");
}

// ===================== SETUP =====================
void setup() {
  Serial.begin(115200);

  capServo.setPeriodHertz(50);
  doorServo.setPeriodHertz(50);
  collectorServo.setPeriodHertz(50);

  capServo.attach(CAP_SERVO_PIN, 500, 2400);
  doorServo.attach(DOOR_SERVO_PIN, 500, 2400);
  collectorServo.attach(COLLECTOR_SERVO_PIN, 500, 2400);

  // We assume the servos are already placed at these startup positions.
  // So we write them once as the tracked initial positions.
  capServo.write(capCurrentAngle);
  doorServo.write(doorCurrentAngle);
  collectorServo.write(collectorCurrentAngle);

  Serial.println();
  Serial.println("3-Servo Test Ready.");
  printHelp();
  printStatus();
}

// ===================== LOOP =====================
void loop() {
  while (Serial.available()) {
    char c = Serial.read();

    if (c == '\n' || c == '\r') {
      if (inputLine.length() > 0) {
        processCommand(inputLine);
        inputLine = "";
      }
    } else {
      inputLine += c;
    }
  }
}